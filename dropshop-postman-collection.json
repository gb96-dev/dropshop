          }
        }
      ]
    },
    {
      "name": "7. Payment (결제)",
      "item": [
        {
          "name": "결제 준비",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.paymentId) {",
                  "  pm.collectionVariables.set('paymentId', res.data.paymentId);",
                  "  console.log('paymentId 저장:', res.data.paymentId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/prepare",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "prepare"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": {{orderId}}\n}"
            },
            "description": "PortOne 결제창 호출 전 사전 준비. paymentId 및 결제 금액 반환"
          }
        },
        {
          "name": "결제 확인 (Confirm)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
