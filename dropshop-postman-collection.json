{
  "info": {
    "name": "Dropshop API - 통합 테스트",
    "_postman_id": "dropshop-integration-v1",
    "description": "Dropshop 전체 API 통합 테스트 컬렉션\n\n## 테스트 순서\n1. Auth - 회원가입 / 로그인\n2. Seller - 판매자 신청\n3. Product - 상품 등록\n4. Drop - 드랍 생성\n5. Queue - 대기열 입장\n6. Order - 주문 생성\n7. Payment - 결제 준비 / 확인\n8. Wishlist - 위시리스트\n9. Notification - 알림\n10. Recommendation - RAG 상품 추천\n11. Refund - 환불\n12. Statistics - 판매 통계",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "dropId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "paymentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "wishlistId",
      "value": "",
      "type": "string"
    },
    {
      "key": "refundId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Auth (인증)",
      "item": [
        {
          "name": "회원가입 (일반 유저)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@test.com\",\n  \"password\": \"Test1234!\",\n  \"nickname\": \"테스트구매자\"\n}"
            },
            "description": "일반 유저 회원가입.\n- password: 8-20자, 영문+숫자+특수문자 조합\n- nickname: 2-10자"
          }
        },
        {
          "name": "회원가입 (판매자용)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@test.com\",\n  \"password\": \"Test1234!\",\n  \"nickname\": \"테스트판매자\"\n}"
            },
            "description": "판매자 신청을 위한 사전 회원가입 계정"
          }
        },
        {
          "name": "로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('토큰 저장 완료');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@test.com\",\n  \"password\": \"Test1234!\"\n}"
            },
            "description": "로그인 성공 시 accessToken / refreshToken 자동 저장 (Tests 탭 스크립트)"
          }
        },
        {
          "name": "토큰 재발급 (Refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "refreshToken으로 accessToken 재발급"
          }
        },
        {
          "name": "로그아웃",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "로그아웃 (토큰 무효화)"
          }
        }
      ]
    },
    {
      "name": "2. Seller (판매자)",
      "item": [
        {
          "name": "판매자 신청",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/apply",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "apply"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"테스트 셀러샵\",\n  \"businessNumber\": \"123-45-67890\",\n  \"contactEmail\": \"seller@test.com\"\n}"
            },
            "description": "일반 유저 → 판매자 신청. 관리자 승인 후 SELLER 권한 부여"
          }
        },
        {
          "name": "판매자 신청 상태 조회",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/me/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "me", "status"]
            },
            "description": "내 판매자 신청 상태 조회 (PENDING / APPROVED / REJECTED)"
          }
        }
      ]
    },
    {
      "name": "3. Product (상품)",
      "item": [
        {
          "name": "상품 등록",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.productId) {",
                  "  pm.collectionVariables.set('productId', res.data.productId);",
                  "  console.log('productId 저장:', res.data.productId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "products"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"에어맥스 90 화이트 스니커즈\",\n  \"category\": \"신발\",\n  \"price\": 150000,\n  \"discountRate\": 10,\n  \"stock\": 100,\n  \"description\": \"클래식한 에어맥스 디자인에 화이트 컬러웨이. 여름철 캐주얼 코디에 최적화된 경량 스니커즈.\",\n  \"specification\": \"소재: 합성피혁 / 밑창: 고무 / 사이즈: 230-290\",\n  \"deliveryInfo\": \"주문 후 2-3일 이내 배송\",\n  \"refundPolicy\": \"수령 후 7일 이내 교환/반품 가능\",\n  \"images\": [\n    {\n      \"imageUrl\": \"https://example.com/images/airmax90_1.jpg\",\n      \"sortOrder\": 1,\n      \"isThumbnail\": true\n    }\n  ]\n}"
            },
            "description": "판매자 권한 필요. productId가 응답에 포함되면 자동으로 컬렉션 변수에 저장됨"
          }
        },
        {
          "name": "상품 목록 조회",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?page=0&size=20&sort=createdAt,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "createdAt,desc" }
              ]
            },
            "description": "전체 상품 목록 (페이지네이션). 비로그인 접근 가능"
          }
        },
        {
          "name": "상품 상세 조회",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            },
            "description": "특정 상품 상세 조회"
          }
        },
        {
          "name": "내 상품 목록 조회 (판매자)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/products?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "판매자 본인 상품 목록"
          }
        }
      ]
    },
    {
      "name": "4. Drop (드랍)",
      "item": [
        {
          "name": "드랍 생성",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.dropId) {",
                  "  pm.collectionVariables.set('dropId', res.data.dropId);",
                  "  console.log('dropId 저장:', res.data.dropId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/drops",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "drops"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"startAt\": \"2026-05-10T10:00:00\",\n  \"endAt\": \"2026-05-10T12:00:00\",\n  \"totalStock\": 50,\n  \"purchaseLimit\": 2,\n  \"useQueue\": true\n}"
            },
            "description": "드랍 생성. useQueue=true 시 대기열 기반 선착순 판매\n- startAt / endAt: ISO-8601 형식\n- purchaseLimit: 1인당 최대 구매 수량\n- totalStock: product.stock 이하여야 함"
          }
        },
        {
          "name": "드랍 목록 조회",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/drops?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "drops"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "활성 드랍 목록"
          }
        },
        {
          "name": "드랍 상세 조회",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/drops/{{dropId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "drops", "{{dropId}}"]
            },
            "description": "특정 드랍 상세 정보 (상품 정보, 남은 재고, 대기열 여부 포함)"
          }
        }
      ]
    },
    {
      "name": "5. Queue (대기열)",
      "item": [
        {
          "name": "대기열 입장",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/queues?dropId={{dropId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "queues"],
              "query": [
                { "key": "dropId", "value": "{{dropId}}" }
              ]
            },
            "description": "드랍 대기열 입장 (useQueue=true인 드랍에만 해당)\n드랍 시작 전 또는 진행 중 호출 가능"
          }
        }
      ]
    },
    {
      "name": "6. Order (주문)",
