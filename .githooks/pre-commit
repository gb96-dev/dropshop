#!/usr/bin/env sh
set -eu

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo "[pre-commit] Applying spotless format..."
./gradlew --no-daemon --console=plain spotlessApply

echo "[pre-commit] Running checkstyleMain..."
./gradlew --no-daemon --console=plain checkstyleMain

echo "[pre-commit] Done"

